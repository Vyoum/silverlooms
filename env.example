# Copy to .env.local and replace placeholders.

# Runtime (Next.js app + Vercel) — Transaction pooler, port 6543
DATABASE_URL="postgresql://postgres.wdrslpoowatuxcgdowsw:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Local Prisma migrations / db push only — Session pooler, port 5432 (optional on Vercel)
DIRECT_URL="postgresql://postgres.wdrslpoowatuxcgdowsw:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Supabase Auth (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://wdrslpoowatuxcgdowsw.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"

# Enable Google sign-in: Supabase Dashboard → Authentication → Providers → Google

# First super admin — this email gets SUPER_ADMIN on first sign-in
SUPER_ADMIN_EMAIL="you@example.com"
