# Copy to .env.local and replace placeholders.

# Runtime (Next.js app + Vercel) — Transaction pooler, port 6543
DATABASE_URL="postgresql://postgres.wdrslpoowatuxcgdowsw:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Local Prisma migrations / db push only — Session pooler, port 5432 (optional on Vercel)
DIRECT_URL="postgresql://postgres.wdrslpoowatuxcgdowsw:[YOUR-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres"

# Supabase Auth (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL="https://wdrslpoowatuxcgdowsw.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-supabase-anon-key"
# Server-only — required for admin image uploads to Supabase Storage
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# Canonical site URL for OAuth redirects (production — use www; Vercel primary domain)
NEXT_PUBLIC_SITE_URL="https://www.silverlooms.in"
# Server-only override (recommended on Vercel if redirects still hit localhost)
AUTH_SITE_URL="https://www.silverlooms.in"

# In Supabase Dashboard → Authentication → URL Configuration:
# Site URL: https://www.silverlooms.in   (NOT localhost)
# Redirect URLs:
#   https://silverlooms.in/auth/callback
#   https://www.silverlooms.in/auth/callback
#   http://localhost:3000/auth/callback

# Enable Google sign-in: Supabase Dashboard → Authentication → Providers → Google

# First super admin — this email gets SUPER_ADMIN on first sign-in
SUPER_ADMIN_EMAIL="you@example.com"

# Razorpay (Dashboard → Settings → API Keys)
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxx"
RAZORPAY_KEY_SECRET="your-razorpay-secret"

# Razorpay webhooks (Dashboard → Webhooks → Add endpoint)
# URL: https://silverlooms.in/api/webhooks/razorpay
# Events: payment.captured, payment.failed, order.paid
RAZORPAY_WEBHOOK_SECRET="your-webhook-secret"

# Delhivery logistics (live production)
DELHIVERY_API_TOKEN="your-delhivery-live-token"
DELHIVERY_API_BASE_URL="https://track.delhivery.com"
DELHIVERY_CLIENT_NAME="your-registered-delhivery-client-name"
DELHIVERY_PICKUP_LOCATION_NAME="your-registered-warehouse-name"
DELHIVERY_PICKUP_ADDRESS="warehouse street address"
DELHIVERY_PICKUP_PINCODE="302001"
DELHIVERY_PICKUP_PHONE="9999999999"
DELHIVERY_PICKUP_CITY="Jaipur"
DELHIVERY_PICKUP_STATE="Rajasthan"
DELHIVERY_SELLER_GST_TIN="your-gstin"
DELHIVERY_HSN_CODE="6204"
